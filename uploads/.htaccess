# Prevent direct access to uploaded files
# All access must go through secure viewer scripts
Order Deny,Allow
Deny from all

# Allow only specific file types (though direct access is still denied)
<FilesMatch "\.(jpg|jpeg|png)$">
    Order Deny,Allow
    Deny from all
</FilesMatch>

# Prevent directory listing
Options -Indexes

# Set proper permissions for uploaded files
<IfModule mod_php.c>
    php_flag engine off
</IfModule>

# Prevent execution of scripts
<FilesMatch "\.(php|phtml|php3|php4|php5|pl|py|cgi|sh|exe)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>
