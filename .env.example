# Database Configuration
DB_HOST=localhost
DB_PORT=3307
DB_NAME=harar_ras_hotel
DB_USER=root
DB_PASS=

# Hotel Configuration
HOTEL_NAME="Harar Ras Hotel"
HOTEL_EMAIL=info@hararrashotel.com
HOTEL_PHONE=+251-25-666-1234
HOTEL_ADDRESS="Harar, Ethiopia"
CURRENCY=ETB
TIMEZONE=Africa/Addis_Ababa

# Application Settings
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost/hotel-system

# Email Configuration (Optional - for notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_ENCRYPTION=tls

# Payment Gateway Configuration
# (Active gateway: Chapa - configured via CHAPA_SECRET_KEY, CHAPA_PUBLIC_KEY)

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost/final%20project2/oauth-callback.php

# File Upload Settings
MAX_FILE_SIZE=5242880
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,gif
UPLOAD_PATH=uploads/

# Security Settings
SESSION_TIMEOUT=3600
PASSWORD_MIN_LENGTH=8
MAX_LOGIN_ATTEMPTS=5

# Cache Settings
CACHE_ENABLED=true
CACHE_DURATION=3600

# Backup Settings
BACKUP_ENABLED=true
BACKUP_FREQUENCY=daily
BACKUP_RETENTION_DAYS=30